# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (dev, zero setup):
DATABASE_URL=sqlite+aiosqlite:///./pharmacheck.db

# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://pharma_user:strongpassword@localhost:5432/pharmacheck

# ── JWT Keys (RS256) ─────────────────────────────────────────────────────────
# Run:  python scripts/generate_keys.py
# Then paste the output below (keep \n as literal newlines in the PEM blocks)
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
<paste private key here>
-----END PRIVATE KEY-----"

JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
<paste public key here>
-----END PUBLIC KEY-----"

# Token lifetimes
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7

# ── LLM providers (pick one or more — precedence: Gemini > Groq > OpenAI) ────
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GROQ_MODEL=llama-3.1-8b-instant
OPENAI_MODEL=gpt-4o-mini
COMPLIANCE_USE_LLM=1

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT=60/minute

# ── Frontend URL (for CORS) ───────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Debug ────────────────────────────────────────────────────────────────────
SQL_ECHO=0
